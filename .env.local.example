# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# EXAMPLE ONLY — replace with the approved current GSA mileage rate before use.
# Do not treat 0.00 as the live reimbursement rate.
NEXT_PUBLIC_GSA_MILEAGE_RATE=0.00

# Never add SUPABASE_SERVICE_ROLE_KEY to this file or to browser code.

